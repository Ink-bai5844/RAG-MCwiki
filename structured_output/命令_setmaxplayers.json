{
  "title": "命令/setmaxplayers",
  "source_url": "https://zh.minecraft.wiki/w/%E5%91%BD%E4%BB%A4%2Fsetmaxplayers",
  "structured_content": {
    "默认分类": [
      "本条目所述内容仅适用于基岩版和​教育版。"
    ],
    "需要的权限等级": [
      "3"
    ],
    "启用作弊": [
      "设置可加入多人游戏的玩家数量上限。"
    ],
    "语法": [
      "setmaxplayers <maxPlayers: int>"
    ],
    "参数": [
      "maxPlayers: int：int",
      "指定要设置的玩家数量上限值。若此值比当前在线玩家总数要小，或者比服务器容许的最大连接数要大，则此值会被修正至上述约束范围内。",
      "必须为32位整数。且最大值为40。"
    ],
    "基岩版": [
      "1.17.40",
      "1.17.40.20",
      "将maxPlayers: int的最大值从30改为40。"
    ],
    "示例": [
      "设置可加入多人游戏的玩家数量上限为2：/setmaxplayers 2"
    ],
    "携带版": [
      "1.1.0",
      "1.1.0.3",
      "加入了/setmaxplayers。"
    ]
  }
}