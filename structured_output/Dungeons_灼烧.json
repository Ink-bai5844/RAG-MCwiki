    "Burning": [
      "每0.5秒对临近的所有敌人造成伤害。"
    ],
    "——魔咒描述": [
      "灼烧（Burning）是Minecraft Dungeons中的魔咒。效果为在自身周围生成一个火环，并以每0.5秒的频率对在火环范围内的生物造成火焰伤害，伤害随魔咒等级提升而提高。",
      "灼烧魔咒的伤害可以被烈焰汇聚魔咒加成。"
    ],
    "I": [
      "1x 伤害",
      "1 附魔点数"
    ],
    "II": [
      "2x 伤害",
      "2 附魔点数"
    ],
    "III": [
      "3x 伤害",
      "3 附魔点数"
    ],
    "Minecraft Dungeons": [
      "3月25日Beta更新",
      "加入了灼烧。"
    ]
  }
}