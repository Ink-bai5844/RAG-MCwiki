    "生物音效": [
      "若音符盒顶面上放置了以下生物的生物头颅，玩家敲击或红石激活音符盒时，音符盒会随机播放对应音效（除苦力怕外均为生物的空闲音效），并且显示对应字幕[仅Java版]：",
      "Java版："
    ],
    "（entity.creeper.primed）": [
      "苦力怕：嘶~"
    ],
    "（entity.ender_dragon.ambient）": [
      "末影龙：咆哮"
    ],
    "（entity.piglin.ambient）": [
      "猪灵：哼叫"
    ],
    "（entity.skeleton.ambient）": [
