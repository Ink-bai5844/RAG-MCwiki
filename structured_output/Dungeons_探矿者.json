    "Prospector": [
      "击败敌人会有更高概率掉落绿宝石。"
    ],
    "——魔咒描述": [
      "探矿者（Prospector）是Minecraft Dungeons中的魔咒。可以增加击败敌人后获取绿宝石的机会。获得的概率随着等级提升而增加。"
    ],
    "I": [
      "+100% 掉落概率增加",
      "1 附魔点数"
    ],
    "II": [
      "+200% 掉落概率增加",
      "2 附魔点数"
    ],
    "III": [
      "+300% 掉落概率增加",
      "3 附魔点数"
    ],
    "Minecraft Dungeons": [
      "3月25日Beta更新",
      "加入了探矿者。",
      "1.7.2.0",
      "现在魔咒无需判断伤害来源即可触发。",
      "1.10.2.0",
      "现在也能在远程武器和盔甲上附魔此魔咒。"
    ]
  }
}