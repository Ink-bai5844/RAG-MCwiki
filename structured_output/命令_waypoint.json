{
  "title": "命令/waypoint",
  "source_url": "https://zh.minecraft.wiki/w/%E5%91%BD%E4%BB%A4%2Fwaypoint",
  "structured_content": {
    "默认分类": [
      "本条目所述内容仅适用于Java版。"
    ],
    "需要的权限等级": [
      "2"
    ],
    "无": [
      "列出或更改路径点。"
    ],
    "waypoint list": [
      "列出路径点。"
    ],
    "waypoint modify <waypoint> color hex <color>": [
      "更改路径点颜色。"
    ],
    "waypoint modify <waypoint> style set <style>": [
      "设置路径点样式。"
    ],
    "waypoint modify <waypoint> style reset": [
      "重置路径点样式为默认值。"
    ],
    "参数": [
      "<waypoint>：entity",
      "指定要更改的路径点。",
      "必须为玩家名、目标选择器或UUID。且目标选择器必须为单一数量，否则此命令将无法解析。",
      "<color>：color（在color <color>中）",
      "指定路径点颜色。",
      "必须为队伍颜色名（reset或16个聊天颜色中的一个）。",
      "<color>：hex_color（在color hex <color>中）",
      "指定路径点颜色代码。",
      "必须为十六进制颜色代码，长度必须为3或6个字符。",
      "<style>：resource_location",
      "指定路径点样式名。",
      "若指定的路径点样式不存在，将显示为无效纹理。",
      "必须为命名空间ID，将会在命令执行时根据此ID尝试获取一个未注册内容，或发送至客户端由客户端处理。"
    ],
    "Java版": [
      "1.21.6"
    ],
    "执行失败": [
      "0"
    ],
    "执行成功": [
      "1",
      "1",
      "0"
    ],
    "示例": [
      "列出所有路径点所追踪的生物：/waypoint list",
      "将最近一只猪的路径点传输距离属性基值设置为32.0，并将其路径点颜色设置为金色。",
      "tag@n[type=pig]addwaypoint_testattribute@n[tag=waypoint_test]minecraft:waypoint_transmit_rangebaseset32.0waypointmodify@n[tag=waypoint_test]colorgold"
    ],
    "定位栏": [
      "25w15a",
      "加入了/waypoint。",
      "1.21.6",
      "25w17a",
      "/waypoint不再属于实验性内容。",
      "移除了modify ... fade子命令。",
      "加入了modify ... style子命令。"
    ],
    "画廊": [
      "25w16a中可使用命令改变路径点图标的不透明度"
    ]
  }
}