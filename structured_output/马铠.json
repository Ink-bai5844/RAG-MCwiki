    "[[|]]": [
      "[[|]]0.1",
      "13w18a",
      "移除了马铠的合成配方。",
      "马铠现在可以在丛林神庙、沙漠神殿、地牢、下界要塞、要塞祭坛和村庄铁匠铺中找到。",
      "除此之外，铁马铠还可以在废弃矿井的运输矿车中被找到。",
      "13w21a",
      "马铠现在不再可以堆叠，以免与其他盔甲矛盾。",
      "1.9",
      "15w31a",
      "将马铠加入了末地城的箱子中。",
      "15w43a",
      "略微降低了马铠在下界要塞箱子中的生成率。",
      "15w44a",
      "增加了在沙漠神殿箱子中的生成率。",
      "略微降低了铁马铠在地牢箱子的生成率，移除在废弃矿井运输矿车中的生成。",
      "1.11.1",
      "16w50a",
      "金马铠和铁马铠现在可以烧炼为对应的金粒和铁粒。",
      "1.13",
      "17w45a",
      "更改了马铠的纹理，因为马的模型被更改了。",
      "17w46a",
      "再次更改了马铠的纹理，因为马的模型再次被更改了。",
      "17w47a",
      "在扁平化之前，这些物品的数字ID分别是417、418和419。",
      "18w03a",
      "再次更改了马铠的纹理，因为马的模型再次被更改了。",
      "18w22a",
      "将铁马铠的实体纹理从更改至 。",
      "pre2",
      "更改了铁马铠的纹理。",
      "1.14",
      "18w50a",
      "更改了所有马铠的物品纹理。",
      "2019年2月20日",
      "皮革马铠被宣布将加入Java版。",
      "19w08a",
      "更改了铁、金和钻石马铠的纹理。",
      "加入了皮革马铠，它可以被染成12,326,391种不同的颜色，类似于皮革盔甲。",
      "1.14.1",
      "pre1",
      "根据纹理更新，更改了皮革马铠的物品纹理。",
      "略微更改了铁马铠的物品纹理。",
      "1.16",
      "20w15a",
      "马铠现在可以由发射器装备到被驯服的马上。",
      "1.17",
      "21w13a",
      "皮革马铠现在可以保护马免受冰冻伤害。",
      "1.19",
      "22w13a",
      "钻石马铠现在可以在远古城市的战利品箱子中找到。",
      "1.20.3"
    ],
    "锻造": [
      "下界合金马铠可通过在锻造台中升级钻石马铠来获得，魔咒和自定义名称等物品数据会被保留。"
    ],
    "生物掉落": [
      "由玩家装备上马铠的马在死亡时总是会掉落一个对应的马铠。"
    ],
    "专家级皮匠": [
      "100%",
      "绿宝石 × 6"
    ],
    "用途": [
      "玩家可以为已驯服的马装备或变更马铠。玩家手持马铠时对没有装备马铠的马使用可为其装备马铠，也可以在马的交互界面中的马铠槽位（）放入或移除马铠。绑定诅咒魔咒不会影响玩家移除马铠。",
      "马铠没有耐久度，因此可以无限地使用，不会因承受伤害而损毁。",
      "只有马和僵尸马可以装备马铠。驴、骡、骷髅马和羊驼不能装备马铠。",
      "在无骑乘物时，对装备马铠的马或僵尸马使用剪刀可以剪下所装备的马铠。",
      "物品实体形式的下界合金马铠会漂浮在熔岩上，且不会被火和熔岩摧毁。"
    ],
    "提供护甲值": [
      "主条目：盔甲机制",
      "马铠在被装备时会提供护甲值属性（armor）。"
    ],
    "下界合金马铠": [
      "19（ × 9.5）",
      "3",
      "10%"
    ],
    "提供盔甲韧性": [
      "主条目：盔甲机制",
      "钻石马铠或下界合金马铠在被装备时会提供盔甲韧性属性（armor_toughness）。"
    ],
    "提供击退抗性": [
      "本段落所述内容仅适用于基岩版。",
      "主条目：伤害 § 击退抗性",
      "下界合金质马铠在被装备时会提供击退抗性，即属性knockback_resistance。"
    ],
    "抵抗细雪": [
      "装备了皮革马铠的马不会因接触细雪而被冰冻。"
    ],
    "僵尸马": [
      "装备了任意马铠的僵尸马不会在阳光下着火。"
    ],
    "染色": [
      "主条目：染料 § 盔甲",
      "皮革马铠可以被染成12,326,391种颜色。",
      "在基岩版中，手持染色的马铠对着装有水的炼药锅使用可以洗掉颜色。",
      "正在加载互动小工具。如果加载失败，请您刷新本页面并检查JavaScript是否已启用。"
    ],
    "音效": [
      "Java版："
    ],
