{
  "title": "命令/spectate",
  "source_url": "https://zh.minecraft.wiki/w/%E5%91%BD%E4%BB%A4%2Fspectate",
  "structured_content": {
    "默认分类": [
      "本条目介绍的是命令。关于允许玩家以飞行的方式无障碍穿过方块和实体并观察世界的游戏模式，请见“旁观模式”。",
      "本条目所述内容仅适用于Java版。"
    ],
    "spectate": [
      "停止旁观实体。"
    ],
    "需要的权限等级": [
      "2"
    ],
    "无": [
      "使用此命令可以使得处于旁观模式的玩家进入另一个实体的视角。"
    ],
    "spectate <target> [<player>]": [
      "让一个玩家旁观另一个实体。"
    ],
    "参数": [
      "<target>：entity",
      "玩家要旁观的实体。",
      "必须为玩家名、目标选择器或UUID。且目标选择器必须为单一数量，否则此命令将无法解析。",
      "<player>：entity",
      "要旁观的玩家。若未指定，则使用命令执行者。",
      "必须为玩家名、目标选择器或UUID。且目标选择器必须为单一数量和玩家类型，否则此命令将无法解析。"
    ],
    "Java版": [
      "1.15",
      "19w41a",
      "加入了/spectate命令。",
      "1.19.4",
      "23w03a",
      "现在/spectate可以跨维度使用。"
    ],
    "执行失败": [
      "0"
    ],
    "执行成功": [
      "1"
    ],
    "示例": [
      "令自己旁观Steve：/spectate Steve",
      "令Steve旁观最近的猪：/spectate @n[type=pig] Steve",
      "令自己停止旁观实体：/spectate"
    ],
    "参考": [
      "MC-224960 — 漏洞状态为“已修复”。"
    ]
  }
}