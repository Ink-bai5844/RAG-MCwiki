  "structured_content": {
    "Altruistic": [
      "受到伤害会治疗你的盟友。"
    ],
    "——游戏内描述": [
      "舍己为人（Heals Allies）是Minecraft Dungeons中的魔咒，会在玩家受伤后治疗其周围的其他玩家和宠物。",
      "此魔咒已经在附魔生物中实装，但未开放给玩家自主附魔。",
      "由于资源文件齐全，通过修改游戏可以给物品强行附上此魔咒并生效。"
    ],
    "I": [
      "受伤的25%转化治疗",
      "2 附魔点数"
    ],
    "II": [
      "受伤的50%转化治疗",
      "3 附魔点数"
    ],
    "III": [
      "受伤的75%转化治疗",
      "4 附魔点数"
    ]
  }
}