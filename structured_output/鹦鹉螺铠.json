    "用途": [
      "玩家可以为已驯服的成年鹦鹉螺和已驯服的僵尸鹦鹉螺装备或变更鹦鹉螺铠。对没有装备鹦鹉螺铠的鹦鹉螺或僵尸鹦鹉螺使用鹦鹉螺铠可为其装备。也可以在鹦鹉螺或僵尸鹦鹉螺的交互界面中的鹦鹉螺铠槽位（）放入或移除鹦鹉螺铠。",
      "在无乘客时，对装备鹦鹉螺铠的鹦鹉螺或僵尸鹦鹉螺使用剪刀可以剪下所装备的鹦鹉螺铠。绑定诅咒不会影响玩家移除鹦鹉螺铠。",
      "鹦鹉螺铠没有耐久度，因此可以无限地使用，不会因承受伤害而损毁。",
      "物品实体形式的下界合金鹦鹉螺铠会漂浮在熔岩上，且不会被火和熔岩摧毁。"
    ],
    "提供护甲值": [
      "主条目：盔甲机制",
      "鹦鹉螺铠在被装备时会提供护甲值属性（armor）。"
    ],
    "下界合金鹦鹉螺铠": [
      "19（ × 9.5）",
      "3",
      "10%"
    ],
    "提供盔甲韧性": [
      "主条目：盔甲机制",
      "钻石鹦鹉螺铠或下界合金鹦鹉螺铠在被装备时会提供盔甲韧性属性（armor_toughness）。"
    ],
    "提供击退抗性": [
      "本段落所述内容仅适用于基岩版。",
      "主条目：伤害 § 击退抗性",
      "下界合金鹦鹉螺铠在被装备时会提供击退抗性，即属性knockback_resistance。"
    ],
    "猪灵": [
      "猪灵会被金鹦鹉螺铠吸引并前往拾取地上的金鹦鹉螺铠，端详6秒[仅Java版]或8秒[仅基岩版]后收进它们的物品栏。"
    ],
    "僵尸鹦鹉螺": [
      "装备了任意鹦鹉螺铠的僵尸鹦鹉螺不会在阳光下着火。"
    ],
