  "structured_content": {
    "默认分类": [
      "本条目介绍的是Minecraft中的绿宝石。关于Minecraft Dungeons中的游戏货币，请见“MCD:绿宝石”。"
    ],
    "[[|]]": [
      "[[|]]9",
      "[[|]]1"
    ],
    "最大堆叠": [
      "64"
    ],
    "emerald": [
      "绿宝石（Emerald）是一种主要用作交易货币的物品。"
    ],
    "挖掘": [
      "绿宝石矿石或深层绿宝石矿石被铁镐或品质更好的镐挖掘后会掉落1个绿宝石。使用带有时运魔咒的镐挖掘会每等级增加1个最大掉落数量，时运III最多会掉落4个绿宝石。如果使用带有精准采集魔咒的镐挖掘，它会掉落自身而非绿宝石。"
    ],
    "交易": [
      "主条目：交易",
      "通过与村民和流浪商人交易可以获得绿宝石。",
      "主条目：交易",
      "绿宝石主要用作与村民和流浪商人交易的货币。"
    ],
    "生物掉落物": [
      "成年狐狸自然生成时有1%的概率在嘴里叼着绿宝石，且其死亡时叼着的绿宝石总是会掉落。",
      "Java版："
    ],
