{
  "title": "命令/getchunkdata",
  "source_url": "https://zh.minecraft.wiki/w/%E5%91%BD%E4%BB%A4%2Fgetchunkdata",
  "structured_content": {
    "默认分类": [
      "此条目所介绍的内容已从基岩版中移除。",
      "这些特性曾存在于游戏中，但已被移除。",
      "本条目所述内容仅适用于教育版。"
    ],
    "需要的权限等级": [
      "3"
    ],
    "启用作弊": [
      "获取指定区块的像素。"
    ],
    "语法": [
      "getchunkdata <dimension: Dimension> <chunkX：int> <chunkZ：int> <height: int>"
    ],
    "参数": [
      "dimension: Dimension：enum",
      "指定维度。",
      "必须为命名空间ID，将会在命令执行时尝试获取对应的维度。minecraft命名空间下的维度默认有overworld、​nether和​the_end。",
      "chunkX: int：int",
      "指定区块的X轴坐标。",
      "必须为32位整数。",
      "chunkZ: int：int",
      "指定区块的Z轴坐标。",
      "必须为32位整数。",
      "height: int：int",
      "指定区块的高度。",
      "必须为32位整数。"
    ],
    "示例": [
      "获取主世界(0,-60,0)处的区块像素：/getchunkdata overworld 0 0 -60"
    ],
    "?": [
      "加入了/getchunkdata命令。"
    ]
  }
}