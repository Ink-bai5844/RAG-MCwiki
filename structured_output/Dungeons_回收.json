    "Recycler": [
      "射中的箭有概率回收成掉落物。"
    ],
    "——魔咒描述": [
      "回收（Recycler）是Minecraft Dungeons中的魔咒，作用为射中玩家的箭能够回收成掉落物。触发频率随着等级提高而提高。"
    ],
    "I": [
      "射击30次后",
      "1 魔咒点数"
    ],
    "II": [
      "射击20次后",
      "2 魔咒点数"
    ],
    "III": [
      "射击10次后",
      "3 魔咒点数"
    ],
    "Minecraft Dungeons": [
      "3月25日Beta更新",
      "加入了回收。"
    ]
  }
}