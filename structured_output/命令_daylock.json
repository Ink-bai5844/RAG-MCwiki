  "structured_content": {
    "默认分类": [
      "本条目所述内容仅适用于基岩版和​教育版。"
    ],
    "需要的权限等级": [
      "1"
    ],
    "启用作弊": [
      "锁定或解锁终为白日。"
    ],
    "语法": [
      "daylock [lock: Boolean]"
    ],
    "参数": [
      "lock: Boolean：Enum",
      "指定是否锁定终为白日。必须为true或false，默认为true。",
      "若为false，将同时打开昼夜更替，反之亦然，并同时设置游戏时间为5000刻，游戏正午前1小时。"
    ],
    "基岩版": [
      "1.2.0",
      "1.2.0.2",
      "加入了/daylock。"
    ],
