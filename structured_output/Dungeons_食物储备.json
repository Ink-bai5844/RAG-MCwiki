      "1个食物",
      "1 魔咒点数"
    ],
    "II": [
      "2个食物",
      "2 魔咒点数"
    ],
    "III": [
      "3个食物",
      "3 魔咒点数"
    ],
    "Minecraft Dungeons": [
      "3月25日Beta更新",
      "加入了食物储备。",
      "1.3.2.0",
      "修复魔咒生成的消耗品不会在在线多人游戏下让所有玩家看到的漏洞。"
    ]
