      "1 魔咒点数"
    ],
    "II": [
      "7% 最大生命值吸取",
      "2 魔咒点数"
    ],
    "III": [
      "9% 最大生命值吸取",
      "3 魔咒点数"
    ],
    "Minecraft Dungeons": [
      "3月25日Beta更新"
    ],
