    "需要的权限等级": [
      "3"
    ],
    "启用作弊": [
      "为全体玩家设置是否全局暂停游戏。"
    ],
    "语法": [
      "globalpause [isPaused: Boolean]"
    ],
    "参数": [
      "isPaused: Boolean：enum",
      "指定游戏是否全局暂停。",
      "若未指定，则查询游戏的全局暂停状态。",
      "必须为 布尔值（true或false）。"
    ],
    "?": [
      "加入了/globalpause命令。"
    ]
  }
