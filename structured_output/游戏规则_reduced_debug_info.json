{
  "title": "游戏规则/reduced debug info",
  "source_url": "https://zh.minecraft.wiki/w/%E6%B8%B8%E6%88%8F%E8%A7%84%E5%88%99%2Freduced_debug_info",
  "structured_content": {
    "默认分类": [
      "本条目所述内容仅适用于Java版。"
    ],
    "reduced_debug_info": [
      "reduced_debug_info是控制是否简化调试信息的游戏规则。"
    ],
    "描述": [
      "限制调试屏幕内容。"
    ],
    "行为": [
      "当reduced_debug_info为true时：",
      "调试屏幕会显示简化的信息。",
      "不能使用F3 + B查看实体边界箱。",
      "不能使用F3 + G查看区块边界。",
      "不能使用F3 + C复制当前坐标。",
      "不能使用F3 + I复制方块实体或实体的数据。"
    ],
    "Java版": [
      "1.8",
      "14w29a",
      "加入了游戏规则reducedDebugInfo。",
      "1.21.11",
      "25w44a",
      "将游戏规则reducedDebugInfo重命名为reduced_debug_info。"
    ]
  }
}