{
  "title": "游戏规则/spawn mobs",
  "source_url": "https://zh.minecraft.wiki/w/%E6%B8%B8%E6%88%8F%E8%A7%84%E5%88%99%2Fspawn_mobs",
  "structured_content": {
    "描述": [
      "一些实体可能有其特定的规则。"
    ],
    "doMobSpawning": [
      "spawn_mobs[仅Java版]或doMobSpawning[仅基岩版]是控制生物是否自然生成的游戏规则。"
    ],
    "行为": [
      "当spawn_mobs[仅Java版]或doMobSpawning[仅基岩版]为false时：",
      "禁用所有周期生成。",
      "禁用所有计划周期生成。",
      "试炼刷怪笼不会激活，不会转变为不祥试炼刷怪笼。",
      "嘎枝之心不会生成嘎枝。",
      "在Java版中，禁用僵尸增援。",
      "使用末影珍珠传送时不会生成末影螨。",
      "闪电不会生成骷髅陷阱马。",
      "此游戏规则不影响伴随区块生成。",
      "此游戏规则不影响其他实体（如生物繁殖、村民生成铁傀儡）、方块（如刷怪笼和虫蚀方块）、物品（生物桶）、袭击驱动的生物生成。"
    ],
    "Java版": [
      "1.4.2",
      "12w32a",
      "加入了游戏规则doMobSpawning。",
      "1.21.11",
      "25w44a",
      "将游戏规则doMobSpawning重命名为spawn_mobs。"
    ],
    "携带版": [
      "1.1.0",
      "1.1.0.0",
      "加入了游戏规则doMobSpawning。"
    ],
    "参考": [
      "MC-266487"
    ]
  }
}