  "structured_content": {
    "默认分类": [
      "门的方块数据分别存储在上半部分和下半部分中。",
      "上半部分储存门轴方向和激活状态。",
      "下半部分储存门的朝向和开启状态。"
    ],
    "（门下半部分）": [
      "0x1",
      "门轴方向：",
      "0：门轴位于左侧（默认）",
      "1：门轴位于右侧",
      "一个值范围0-3的2位二进制数，储存门的朝向：",
      "0：朝向西方",
      "1：朝向北方",
      "2：朝向东方",
      "3：朝向南方",
      "0x2"
    ],
    "门是否被激活": [
      "0x4"
    ],
    "门是否开启": [
      "0x8"
    ],
    "是否为门的上半部分": [
      "（对门的上半部分，该位总为1）",
      "（对门的下半部分，该位总为0）"
    ]
  }
}