    "doInsomnia": [
      "spawn_phantoms[仅Java版]或doInsomnia[仅基岩版]是控制幻翼是否能够在夜晚生成的游戏规则。"
    ],
    "行为": [
      "当spawn_phantoms[仅Java版]或doInsomnia[仅基岩版]为false时，幻翼不会自然生成。"
    ],
    "Java版": [
      "1.15",
      "19w36a",
      "加入了游戏规则doInsomnia。",
      "1.21.11",
      "25w44a",
      "将游戏规则doInsomnia重命名为spawn_phantoms。"
    ],
    "基岩版": [
      "1.6.0",
      "1.6.0.6",
      "加入了游戏规则doInsomnia。"
    ]
  }
}